# Try to extract the name - it's often nested like this:
name <- tryCatch(stream_info[[1]][[1]], error = function(e) "Unknown")
type <- tryCatch(stream_info[[2]][[1]], error = function(e) "Unknown")
cat(paste0("Stream ", i, ": Name = ", name, " | Type = ", type, "\n"))
}
